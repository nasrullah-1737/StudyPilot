<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StudyPilot.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:StudyPilot.ViewModels"
    x:DataType="viewModels:RegisterViewModel"
    Shell.NavBarIsVisible="False">
    <ScrollView VerticalScrollBarVisibility="Always">
        <VerticalStackLayout Padding="24,48" Spacing="16">
            <!-- PLACEHOLDER_IMAGE_REGISTER_HEADER: optional onboarding image/icon -->
            <Image Source="register_header_placeholder.png" HeightRequest="64" HorizontalOptions="Center" IsVisible="False" />
            <Label Text="Create Account" Style="{StaticResource PageTitleLabel}" HorizontalOptions="Center" />

            <Frame Style="{StaticResource AppCardStyle}">
                <VerticalStackLayout Spacing="10">
                    <Entry Placeholder="Full name" Text="{Binding Name}" />
                    <Entry Placeholder="Email address" Text="{Binding Email}" Keyboard="Email" />
                    <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" />
                    <Entry Placeholder="Confirm password" Text="{Binding ConfirmPassword}" IsPassword="True" />

                    <Button Text="Register" Command="{Binding RegisterCommand}" />
                    <Button Text="Back to Login" Command="{Binding BackToLoginCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
