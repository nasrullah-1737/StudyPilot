<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StudyPilot.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:StudyPilot.Models"
    xmlns:viewModels="clr-namespace:StudyPilot.ViewModels"
    x:Name="TasksPageRoot"
    x:DataType="viewModels:TasksViewModel"
    Title="Tasks">
    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="10">
        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <!-- PLACEHOLDER_IMAGE_TASKS_HEADER: add custom icon/illustration -->
            <Image Source="tasks_header_placeholder.png" HeightRequest="56" HorizontalOptions="Start" IsVisible="False" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Picker
                    Title="Filter"
                    ItemsSource="{Binding Filters}"
                    SelectedItem="{Binding SelectedFilter}" />
                <Button Grid.Column="1" Text="Add" Command="{Binding AddCommand}" />
            </Grid>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Tasks}" SelectionMode="None" VerticalScrollBarVisibility="Always">
            <CollectionView.EmptyView>
                <Label Text="No tasks yet." Style="{StaticResource BodyLabel}" HorizontalOptions="Center" Margin="0,24,0,0" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TaskItem">
                    <Frame Style="{StaticResource AppCardStyle}">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Title}" FontFamily="OpenSansSemibold" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="{Binding Description}" Style="{StaticResource BodyLabel}" MaxLines="2" />
                                    <Label Text="{Binding Deadline, StringFormat='Due: {0:dd MMM hh:mm tt}'}" Style="{StaticResource BodyLabel}" />
                                    <Label Text="{Binding Priority, StringFormat='Priority: {0}'}" Style="{StaticResource BodyLabel}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding IsCompleted, StringFormat='Done: {0}'}" Style="{StaticResource BodyLabel}" VerticalOptions="Center" />
                            </Grid>
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <Button
                                    Text="Toggle"
                                    Command="{Binding Source={x:Reference TasksPageRoot}, Path=BindingContext.ToggleCompletedCommand}"
                                    CommandParameter="{Binding .}" />
                                <Button
                                    Grid.Column="1"
                                    Text="Edit"
                                    Command="{Binding Source={x:Reference TasksPageRoot}, Path=BindingContext.EditCommand}"
                                    CommandParameter="{Binding .}"
                                    Style="{StaticResource SecondaryButtonStyle}" BackgroundColor="Yellow" />
                                <Button
                                    Grid.Column="2"
                                    Text="Delete"
                                    Command="{Binding Source={x:Reference TasksPageRoot}, Path=BindingContext.DeleteCommand}" BackgroundColor="Red"
                                    CommandParameter="{Binding .}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
