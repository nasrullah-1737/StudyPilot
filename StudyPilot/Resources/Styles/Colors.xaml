<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Color x:Key="Primary">#3A6FD9</Color>
    <Color x:Key="PrimaryLight">#5D8AE5</Color>
    <Color x:Key="PrimaryDark">#234B9A</Color>
    <Color x:Key="Background">#F2F7FF</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="TextPrimary">#17304F</Color>
    <Color x:Key="TextSecondary">#5B7394</Color>
    <Color x:Key="Border">#D9E6FA</Color>
    <Color x:Key="Success">#2E9E62</Color>
    <Color x:Key="Warning">#EF9B28</Color>
    <Color x:Key="Danger">#D95757</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}" />
</ResourceDictionary>
