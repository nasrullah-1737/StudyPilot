<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StudyPilot.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:StudyPilot.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="StudyPilot">
    <!-- PLACEHOLDER_ICON_TABS: Replace dotnet_bot.png with your custom tab icons in Resources/Images -->
    <TabBar Route="main">
        <ShellContent
            Title="Home"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="dashboard" />
        <ShellContent
            Title="Notes"
            Icon="notes.png"
            ContentTemplate="{DataTemplate views:NotesPage}"
            Route="notes" />
        <ShellContent
            Title="Tasks"
            Icon="tasks.png"
            ContentTemplate="{DataTemplate views:TasksPage}"
            Route="tasks" />
        <ShellContent
            Title="Schedule"
            Icon="schedule.png"
            ContentTemplate="{DataTemplate views:TimetablePage}"
            Route="schedule" />
        <ShellContent
            Title="Focus"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:FocusPage}"
            Route="focus" />
        <ShellContent
            Title="Files"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:FilesPage}"
            Route="files" />
    </TabBar>

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="login" />
    <ShellContent
        Title="Register"
        ContentTemplate="{DataTemplate views:RegisterPage}"
        Route="register" />
</Shell>
